{
  "name": "pi-tasks",
  "version": "0.2.0-dev",
  "description": "A task tool for pi agents — session-scoped tasks with a live above-editor widget and compact tool output",
  "keywords": [
    "pi-package",
    "tasks",
    "todowrite"
  ],
  "license": "MIT",
  "author": "josorio7122",
  "repository": "github:josorio7122/pi-tasks",
  "type": "module",
  "exports": {
    ".": "./src/api.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --fix src/",
    "check": "npm run lint && npm run lint:blanks && npm run typecheck && npm run test",
    "format": "biome format --write src/",
    "simulate": "tsx scripts/simulate-ui.ts",
    "test:e2e": "PI_E2E=1 vitest run --config vitest.e2e.config.ts",
    "prepare": "simple-git-hooks",
    "lint:blanks": "bash scripts/check-blank-lines.sh"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*",
    "@types/node": "^25.5.0",
    "@types/proper-lockfile": "^4.1.4",
    "lint-staged": "^16.4.0",
    "simple-git-hooks": "^2.13.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "src",
    "agents",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "biome check --fix --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "proper-lockfile": "^4.1.2"
  }
}
